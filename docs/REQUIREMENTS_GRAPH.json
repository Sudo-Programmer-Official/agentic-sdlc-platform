    {
      "id": "FR-001",
      "type": "FR",
      "text": "1 Page rendering: Serve a responsive landing page with hero, value props, social proof, pricing/CTA, and FAQ sections.",
      "confidence": 0.95,
      "source": "AI_EXTRACTED",
      "quality_type": null,
      "tags": []
    },
    {
      "id": "FR-002",
      "type": "FR",
      "text": "2 CTA actions: Support primary CTA (Start Free, Book Demo, etc.) and secondary CTA (Learn More) with configurable destination links.",
      "confidence": 0.95,
      "source": "AI_EXTRACTED",
      "quality_type": null,
      "tags": []
    },
    {
      "id": "FR-003",
      "type": "FR",
      "text": "3 Lead capture form: Collect name, work email, company, and optional phone/message with validation and error handling.",
      "confidence": 0.95,
      "source": "AI_EXTRACTED",
      "quality_type": null,
      "tags": []
    },
    {
      "id": "FR-004",
      "type": "FR",
      "text": "4 Form submission backend: Persist leads to database and return success/failure state.",
      "confidence": 0.95,
      "source": "AI_EXTRACTED",
      "quality_type": null,
      "tags": []
    },
    {
      "id": "FR-005",
      "type": "FR",
      "text": "5 CRM integration: Push captured leads to CRM (e.g., HubSpot/Salesforce) with source metadata (campaign, UTM).",
      "confidence": 0.95,
      "source": "AI_EXTRACTED",
      "quality_type": null,
      "tags": []
    },
    {
      "id": "FR-006",
      "type": "FR",
      "text": "6 UTM tracking: Parse and store utm_source, utm_medium, utm_campaign, utm_content, utm_term.",
